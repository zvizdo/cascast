{
  "name": "mountain-weatherman-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest.config.ts",
    "test:integration": "firebase emulators:exec --only firestore \"FIRESTORE_EMULATOR_HOST=localhost:8080 npm run seed:emulator && FIRESTORE_EMULATOR_HOST=localhost:8080 vitest run --config config/vitest.integration.config.ts src/app/api/__tests__/integration.emulator.test.ts\"",
    "test:e2e": "playwright test --config config/playwright.config.ts",
    "test:e2e:680": "playwright test --config config/playwright.config.ts --project=narrow",
    "emulators": "firebase emulators:start --only firestore,pubsub",
    "seed:emulator": "tsx scripts/seed-emulator.ts",
    "seed:mountains": "tsx scripts/seed-mountains.ts"
  },
  "dependencies": {
    "@google-cloud/pubsub": "4.9.0",
    "@google-cloud/storage": "7.14.0",
    "@next/third-parties": "16.2.9",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "d3": "7.9.0",
    "firebase-admin": "12.7.0",
    "maplibre-gl": "^4.7.1",
    "next": "16.2.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "server-only": "^0.0.1",
    "swr": "2.3.0",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.10",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "1.51.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/d3": "7.4.3",
    "@types/node": "20.17.0",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.8",
    "autoprefixer": "10.4.20",
    "axe-core": "^4.10.2",
    "eslint": "9.18.0",
    "eslint-config-next": "16.2.7",
    "jsdom": "25.0.1",
    "postcss": "8.5.1",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "vitest-axe": "^0.1.0"
  }
}
